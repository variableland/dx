{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["GITHUB_TOKEN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:types": {},
    "test:unit": {},
    "test:integration": {
      "dependsOn": ["build"]
    }
  }
}
