    "test:types": "rr tsc"
  },
  "dependencies": {
    "@pnpm/fs.find-packages": "1000.0.24",
    "@pnpm/types": "1001.3.0",
    "ansis": "4.2.0",
    "memoize": "10.2.0",
    "pkg-types": "2.3.0",
    "std-env": "3.9.0",
    "tinyexec": "1.1.2",
    "yaml": "2.8.4"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@vlandoss/tsdown-config": "workspace:^"
  }
}
