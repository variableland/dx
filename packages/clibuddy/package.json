{
  "name": "@vlandoss/clibuddy",
  "version": "0.1.0",
  "description": "A helper library to create CLIs in Variable Land",
  "homepage": "https://github.com/variableland/dx/tree/main/packages/clibuddy#readme",
  "bugs": {
    "url": "https://github.com/variableland/dx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/variableland/dx.git",
    "directory": "packages/clibuddy"
  },
  "license": "MIT",
  "author": "rcrd <rcrd@variable.land>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./test-helpers": "./test-helpers/index.ts"
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__",
    "!src/**/*.test.*"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "test:types": "rr tsc"
  },
  "dependencies": {
    "@pnpm/workspace.find-packages": "1000.0.62",
    "@pnpm/workspace.read-manifest": "1000.2.10",
    "chalk": "5.6.2",
    "read-package-up": "12.0.0",
    "supports-color": "10.2.2",
    "zx": "8.8.5"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@vlandoss/tsdown-config": "workspace:^"
  }
}
