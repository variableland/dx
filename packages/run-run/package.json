{
  "name": "@vlandoss/run-run",
  "version": "0.6.0",
  "description": "The CLI toolbox to fullstack common scripts in Variable Land",
  "homepage": "https://github.com/variableland/dx/tree/main/packages/run-run#readme",
  "bugs": {
    "url": "https://github.com/variableland/dx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/variableland/dx.git",
    "directory": "packages/run-run"
  },
  "license": "MIT",
  "author": "rcrd <rcrd@variable.land>",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "exports": {
    "./config": "./src/lib/config.ts",
    "./tools/*": "./src/lib/tools/*.ts"
  },
  "bin": {
    "rr": "./bin",
    "biome": "./tools/biome",
    "oxfmt": "./tools/oxfmt",
    "oxlint": "./tools/oxlint",
    "tsdown": "./tools/tsdown"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/__tests__",
    "!src/**/*.test.*",
    "tools",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      "./config": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      },
      "./tools/*": {
        "types": "./dist/tools/*.d.mts",
        "default": "./dist/tools/*.mjs"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown && pnpm build:kdl",
    "build:kdl": "./bin --usage > dist/cli.usage.kdl",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "prepublishOnly": "pnpm build",
    "test:types": "rr tsc"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.4",
    "@usage-spec/commander": "1.1.0",
    "@vlandoss/clibuddy": "workspace:*",
    "@vlandoss/loggy": "workspace:*",
    "commander": "14.0.3",
    "glob": "13.0.6",
    "lilconfig": "3.1.3",
    "memoize": "10.2.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.15.0",
    "rimraf": "6.1.3",
    "tsdown": "0.22.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@vlandoss/tsdown-config": "workspace:^"
  }
}
