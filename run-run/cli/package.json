{
  "name": "@rrlab/cli",
  "version": "1.1.0",
  "description": "The CLI toolbox to fullstack common scripts in Variable Land",
  "homepage": "https://github.com/variableland/dx/tree/main/run-run/cli#readme",
  "bugs": {
    "url": "https://github.com/variableland/dx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/variableland/dx.git",
    "directory": "run-run/cli"
  },
  "license": "MIT",
  "author": "rcrd <rcrd@variable.land>",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "exports": {
    "./config": "./src/lib/config.ts",
    "./plugin": "./src/lib/plugin.ts"
  },
  "bin": {
    "rr": "./bin"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/__tests__",
    "!src/**/*.test.*",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      "./config": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      },
      "./plugin": {
        "types": "./dist/plugin.d.mts",
        "default": "./dist/plugin.mjs"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown && pnpm build:kdl",
    "build:kdl": "./bin --usage > dist/cli.usage.kdl",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "prepublishOnly": "pnpm build",
    "test:types": "rr tsc"
  },
  "dependencies": {
    "@clack/prompts": "0.11.0",
    "@usage-spec/commander": "1.1.0",
    "@vlandoss/clibuddy": "workspace:*",
    "@vlandoss/loggy": "workspace:*",
    "comment-json": "4.2.5",
    "commander": "14.0.3",
    "glob": "13.0.6",
    "lilconfig": "3.1.3",
    "magicast": "0.3.5",
    "memoize": "10.2.0",
    "nypm": "0.6.0",
    "rimraf": "6.1.3"
  },
  "devDependencies": {
    "@rrlab/tsdown-config": "workspace:^",
    "tsdown": "0.22.0"
  }
}
