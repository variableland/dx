{
  "name": "@rrlab/tsdown-config",
  "version": "0.1.0",
  "description": "Shared tsdown configuration helpers used by @rrlab/tsdown-plugin.",
  "homepage": "https://github.com/variableland/dx/tree/main/run-run/tsdown-config#readme",
  "bugs": {
    "url": "https://github.com/variableland/dx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/variableland/dx.git",
    "directory": "run-run/tsdown-config"
  },
  "license": "MIT",
  "author": "rcrd <rcrd@variable.land>",
  "keywords": [
    "tsdown",
    "config",
    "presets",
    "rrlab"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
